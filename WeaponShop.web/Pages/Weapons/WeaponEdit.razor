@page "/weapons/edit/{Id:int}"

@inject WeaponShop.Application.Services.IWeaponService WeaponService
@inject NavigationManager Navigation

<h3>Edit Weapon</h3>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

@if (Weapon is null)
{
    <p><em>Loading weapon...</em></p>
}
else
{
    <WeaponForm Weapon="Weapon" Title="Edit Weapon" SubmitButtonText="Save" OnValidSubmit="HandleValidSubmit" OnCancel="HandleCancel" />
}

@code {
    [Parameter]
    public int Id { get; set; }

    private WeaponShop.Domain.Weapon? Weapon;
    private string? ErrorMessage;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            Weapon = await WeaponService.GetByIdAsync(Id);
            if (Weapon is null)
            {
                ErrorMessage = $"Weapon with id {Id} was not found.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading weapon: {ex.Message}";
        }
    }

    private async Task HandleValidSubmit()
    {
        if (Weapon is null)
        {
            return;
        }

        try
        {
            await WeaponService.UpdateAsync(Weapon);
            Navigation.NavigateTo("/weapons");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error updating weapon: {ex.Message}";
        }
    }

    private void HandleCancel()
    {
        Navigation.NavigateTo("/weapons");
    }
}

