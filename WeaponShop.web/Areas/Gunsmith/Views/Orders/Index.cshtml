@model IReadOnlyList<Order>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Kontroly zbrojíře</h2>
            <p class="panel-subtitle">Objednávky čekající na kontrolu nebo úpravu zbrojířem.</p>
        </div>
        <a class="btn-soft" asp-action="History">Moje auditní historie</a>
    </div>

    @{
        var statusOptions = new[] { OrderStatus.AwaitingGunsmith };
    }

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        <div class="data-empty">@statusMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="data-empty">@errorMessage</div>
    }

    <form method="get" class="form-shell form-shell-wide" style="margin-bottom: 1rem;">
        <div class="mb-3">
            <label class="field-label" for="statusFilter">Filtr stavu</label>
            <select id="statusFilter" name="status" class="form-control">
                <option value="">Vše</option>
                @foreach (var status in statusOptions)
                {
                    var selected = string.Equals(Context.Request.Query["status"], status.ToString(), StringComparison.OrdinalIgnoreCase);
                    <option value="@status" selected="@(selected ? "selected" : null)">@CatalogPresentation.GetStatusLabel(status)</option>
                }
            </select>
        </div>
        <button class="btn-modern" type="submit">Použít filtr</button>
    </form>

    @if (Model.Count == 0)
    {
        <div class="data-empty">Žádné akce pro zbrojíře aktuálně nečekají.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Objednávka</th>
                        <th>Zákazník</th>
                        <th>Položky</th>
                        <th>Stav</th>
                        <th>Kontroly</th>
                        <th>Audit</th>
                        <th class="text-end">Akce</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>
                                <div>@order.GetPublicOrderNumber()</div>
                                <div class="panel-subtitle">@order.CreatedAt.ToLocalTime().ToString("g")</div>
                            </td>
                            <td>
                                <div>@order.User?.FirstName @order.User?.LastName</div>
                                <div class="panel-subtitle">@order.User?.Email</div>
                            </td>
                            <td>
                                @foreach (var item in order.Items)
                                {
                                    <div>@item.GetDisplayName() x @item.Quantity</div>
                                }
                            </td>
                            <td>
                                <span class="badge-cat">@CatalogPresentation.GetStatusLabel(order.Status)</span>
                            </td>
                            <td>
                                @if (order.WarehouseCheckedAtUtc.HasValue)
                                {
                                    <div class="panel-subtitle">Kontrola skladu: @order.WarehouseCheckedAtUtc.Value.ToLocalTime().ToString("g")</div>
                                }
                            </td>
                            <td>
                                @if (order.Audits.Count == 0)
                                {
                                    <span class="panel-subtitle">Zatím bez auditu</span>
                                }
                                else
                                {
                                    foreach (var audit in order.Audits.OrderByDescending(a => a.OccurredAtUtc))
                                    {
                                        <div class="panel-subtitle">
                                            @audit.OccurredAtUtc.ToLocalTime().ToString("g") -
                                            @audit.ActorName: @CatalogPresentation.GetAuditActionLabel(audit.Action)
                                        </div>
                                    }
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-row">
                                    <a class="btn-inline" asp-action="Details" asp-route-id="@order.Id">Detail</a>
                                    <a class="btn-inline" asp-action="DownloadWord" asp-route-id="@order.Id">Stáhnout DOC</a>
                                    <form asp-action="MarkChecked" method="post">
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <button type="submit" class="btn-inline">Potvrdit kontrolu</button>
                                    </form>
                                    <form asp-action="Reject" method="post">
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <input type="text" name="reason" class="form-control" placeholder="Důvod zamítnutí" />
                                        <button type="submit" class="btn-inline btn-inline-danger">Zamítnout</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
