@model IReadOnlyList<OrderAudit>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Historie skladu</h2>
            <p class="panel-subtitle">Všechny akce, které jste potvrdili nebo zamítli.</p>
        </div>
        <a class="btn-soft" asp-action="Index">Zpět na objednávky</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="data-empty">Zatím nejsou k dispozici žádné auditní záznamy.</div>
    }
    else
    {
        <div class="audit-list">
            @foreach (var audit in Model)
            {
                <div class="audit-card">
                    <div class="audit-card-head">
                        <div class="audit-card-title">Objednávka č. @(audit.Order?.GetPublicOrderNumber() ?? $"WS-{audit.OrderId:D6}") - @CatalogPresentation.GetAuditActionLabel(audit.Action)</div>
                        <span class="badge-cat">@CatalogPresentation.GetStatusLabel(audit.ToStatus)</span>
                    </div>
                    <div class="audit-card-meta">
                        @audit.OccurredAtUtc.ToLocalTime().ToString("g")
                        • @CatalogPresentation.GetStatusLabel(audit.FromStatus) → @CatalogPresentation.GetStatusLabel(audit.ToStatus)
                    </div>
                    <div class="audit-card-body">
                        <div>@audit.Order?.User?.FirstName @audit.Order?.User?.LastName</div>
                        <div class="panel-subtitle">@audit.Order?.User?.Email</div>
                        <div class="panel-subtitle">@audit.ActorName</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(audit.Notes))
                    {
                        <div class="audit-card-notes">Poznámka: @audit.Notes</div>
                    }
                    <div class="audit-card-actions">
                        <a class="btn-inline" asp-action="Details" asp-route-id="@audit.OrderId">Detail</a>
                        <a class="btn-inline" asp-action="DownloadWord" asp-route-id="@audit.OrderId">Stáhnout RTF</a>
                    </div>
                </div>
            }
        </div>
    }
</section>
