@model IReadOnlyList<Order>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Skladnik - Warehouse checks</h2>
            <p class="panel-subtitle">Orders approved by admin or returned from gunsmith.</p>
        </div>
        <a class="btn-soft" asp-action="History">My audit history</a>
    </div>

    @{
        var statusOptions = new[] { OrderStatus.Approved, OrderStatus.AwaitingDispatch, OrderStatus.ReadyForPickup };
    }

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        <div class="data-empty">@statusMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="data-empty">@errorMessage</div>
    }

    <form method="get" class="form-shell form-shell-wide" style="margin-bottom: 1rem;">
        <div class="mb-3">
            <label class="field-label" for="statusFilter">Status filter</label>
            <select id="statusFilter" name="status" class="form-control">
                <option value="">All</option>
                @foreach (var status in statusOptions)
                {
                    var selected = string.Equals(Context.Request.Query["status"], status.ToString(), StringComparison.OrdinalIgnoreCase);
                    <option value="@status" selected="@(selected ? "selected" : null)">@status</option>
                }
            </select>
        </div>
        <button class="btn-modern" type="submit">Apply filter</button>
    </form>

    @if (Model.Count == 0)
    {
        <div class="data-empty">No warehouse actions pending.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Customer</th>
                        <th>Items</th>
                        <th>Status</th>
                        <th>Checks</th>
                        <th>Audit</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>
                                <div>#@order.Id</div>
                                <div class="panel-subtitle">@order.CreatedAt.ToLocalTime().ToString("g")</div>
                            </td>
                            <td>
                                <div>@order.User?.FirstName @order.User?.LastName</div>
                                <div class="panel-subtitle">@order.User?.Email</div>
                            </td>
                            <td>
                                @foreach (var item in order.Items)
                                {
                                    <div>@item.Weapon?.Name x @item.Quantity</div>
                                }
                            </td>
                            <td>
                                <span class="badge-cat">@order.Status</span>
                            </td>
                            <td>
                                @if (order.ApprovedAtUtc.HasValue)
                                {
                                    <div class="panel-subtitle">Admin approved: @order.ApprovedAtUtc.Value.ToLocalTime().ToString("g")</div>
                                }
                                @if (order.WarehouseCheckedAtUtc.HasValue)
                                {
                                    <div class="panel-subtitle">Warehouse check: @order.WarehouseCheckedAtUtc.Value.ToLocalTime().ToString("g")</div>
                                }
                                @if (order.GunsmithCheckedAtUtc.HasValue)
                                {
                                    <div class="panel-subtitle">Gunsmith check: @order.GunsmithCheckedAtUtc.Value.ToLocalTime().ToString("g")</div>
                                }
                                @if (order.PickupHandedOverAtUtc.HasValue)
                                {
                                    <div class="panel-subtitle">Pickup handed over: @order.PickupHandedOverAtUtc.Value.ToLocalTime().ToString("g")</div>
                                }
                            </td>
                            <td>
                                @if (order.Audits.Count == 0)
                                {
                                    <span class="panel-subtitle">No audit yet</span>
                                }
                                else
                                {
                                    foreach (var audit in order.Audits.OrderByDescending(a => a.OccurredAtUtc))
                                    {
                                        <div class="panel-subtitle">
                                            @audit.OccurredAtUtc.ToLocalTime().ToString("g") -
                                            @audit.ActorRole @audit.ActorName: @audit.Action
                                        </div>
                                    }
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-row">
                                    <a class="btn-inline" asp-action="Details" asp-route-id="@order.Id">Details</a>
                                    <a class="btn-inline" asp-action="DownloadWord" asp-route-id="@order.Id">Word</a>
                                    @if (order.Status == OrderStatus.Approved)
                                    {
                                        <form asp-action="SendToGunsmith" method="post">
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <button type="submit" class="btn-inline">Send to gunsmith</button>
                                        </form>
                                    }
                                    @if (order.Status == OrderStatus.AwaitingDispatch)
                                    {
                                        <form asp-action="MarkShipped" method="post">
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <button type="submit" class="btn-inline">Mark shipped</button>
                                        </form>
                                        <form asp-action="MarkReadyForPickup" method="post">
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <button type="submit" class="btn-inline">Ready for pickup</button>
                                        </form>
                                        <form asp-action="Reject" method="post">
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <input type="text" name="reason" class="form-control" placeholder="Reject reason" />
                                            <button type="submit" class="btn-inline btn-inline-danger">Reject</button>
                                        </form>
                                    }
                                    @if (order.Status == OrderStatus.ReadyForPickup)
                                    {
                                        <form asp-action="ConfirmPickup" method="post">
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <button type="submit" class="btn-inline">Confirm pickup</button>
                                        </form>
                                        <form asp-action="Reject" method="post">
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <input type="text" name="reason" class="form-control" placeholder="Reject reason" />
                                            <button type="submit" class="btn-inline btn-inline-danger">Reject</button>
                                        </form>
                                    }
                                    @if (order.Status == OrderStatus.Approved)
                                    {
                                        <form asp-action="Reject" method="post">
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <input type="text" name="reason" class="form-control" placeholder="Reject reason" />
                                            <button type="submit" class="btn-inline btn-inline-danger">Reject</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
