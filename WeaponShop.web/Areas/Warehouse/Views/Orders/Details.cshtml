@model Order

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Objednávka č. @Model.GetPublicOrderNumber()</h2>
            <p class="panel-subtitle">Skladový pohled na kompletní audit a detail objednávky.</p>
        </div>
        <div class="btn-row">
            <a class="btn-soft" asp-action="Index">Zpět na objednávky</a>
            <a class="btn-soft" asp-action="History">Moje auditní historie</a>
            <a class="btn-soft" asp-action="DownloadWord" asp-route-id="@Model.Id">Stáhnout RTF</a>
            <a class="btn-soft" asp-action="ViewInvoice" asp-route-id="@Model.Id" target="_blank" rel="noopener">Náhled faktury</a>
            <a class="btn-soft" asp-action="DownloadInvoice" asp-route-id="@Model.Id">Stáhnout PDF</a>
        </div>
    </div>

    <div class="table-wrap" style="margin-bottom: 1.5rem;">
        <table class="data-grid">
            <tbody>
                <tr>
                    <th>Stav</th>
                    <td><span class="badge-cat">@CatalogPresentation.GetStatusLabel(Model.Status)</span></td>
                    <th>Vytvořeno</th>
                    <td>@Model.CreatedAt.ToLocalTime().ToString("g")</td>
                </tr>
                <tr>
                    <th>Zákazník</th>
                    <td>
                        <div>@Model.User?.FirstName @Model.User?.LastName</div>
                        <div class="panel-subtitle">@Model.User?.Email</div>
                    </td>
                    <th>Celkem</th>
                    <td>@Model.TotalPrice.ToString("C")</td>
                </tr>
                <tr>
                    <th>Schváleno adminem</th>
                    <td>@(Model.ApprovedAtUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                    <th>Kontrola skladu</th>
                    <td>@(Model.WarehouseCheckedAtUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                </tr>
                <tr>
                    <th>Kontrola zbrojíře</th>
                    <td>@(Model.GunsmithCheckedAtUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                    <th>Připraveno skladem</th>
                    <td>@(Model.WarehousePreparedAtUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                </tr>
                <tr>
                    <th>Odesláno</th>
                    <td>@(Model.ShippedAtUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                    <th>Připraveno k vyzvednutí</th>
                    <td>@(Model.ReadyForPickupAtUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                </tr>
                <tr>
                    <th>Předáno zákazníkovi</th>
                    <td>@(Model.PickupHandedOverAtUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                    <th>Zamítnuto</th>
                    <td>@(Model.RejectedAtUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                </tr>
                <tr>
                    <th>Doručení</th>
                    <td>@(Model.DeliveryMethod == "shipping" ? "Doručení na adresu" : "Osobní odběr")</td>
                    <th>Platba</th>
                    <td>@(Model.PaymentMethod == "cash-on-delivery" ? "Dobírka" : Model.PaymentMethod == "cash-on-pickup" ? "Platba při převzetí" : "Bankovní převod")</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="table-wrap" style="margin-bottom: 1.5rem;">
        <table class="data-grid">
            <thead>
                <tr>
                    <th>Položky</th>
                    <th class="text-end">Množství</th>
                    <th class="text-end">Cena za kus</th>
                    <th class="text-end">Cena celkem</th>
                    <th class="text-end">Obrázek</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <div>@item.GetDisplayName()</div>
                            @if (item.IsWeapon && item.Weapon is not null)
                            {
                                <div class="panel-subtitle">@item.Weapon.TypeDesignation • @item.Weapon.Caliber</div>
                                var assignedUnits = item.Weapon.Units
                                    .Where(unit => unit.ReservedOrderId == Model.Id || unit.SoldOrderId == Model.Id)
                                    .OrderBy(unit => unit.PrimarySerialNumber)
                                    .ToList();

                                @foreach (var unit in assignedUnits)
                                {
                                    <div class="panel-subtitle">
                                        <strong>V. č. @unit.PrimarySerialNumber</strong>
                                    </div>

                                    @foreach (var part in unit.Parts.OrderBy(part => part.SlotNumber))
                                    {
                                        <div class="panel-subtitle">@part.PartName: @part.SerialNumber</div>
                                    }
                                }
                            }
                        </td>
                        <td class="text-end">@item.Quantity</td>
                        <td class="text-end">@item.UnitPrice.ToString("C")</td>
                        <td class="text-end">@((item.UnitPrice * item.Quantity).ToString("C"))</td>
                        <td class="text-end">
                            @if (item.IsWeapon && item.WeaponId.HasValue)
                            {
                                <a class="btn-inline"
                                   asp-area=""
                                   asp-controller="Weapons"
                                   asp-action="Details"
                                   asp-route-id="@item.WeaponId"
                                   target="_blank"
                                   rel="noopener">
                                    Zobrazit obrázek
                                </a>
                            }
                            else
                            {
                                <span class="panel-subtitle">-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Status is OrderStatus.Approved or OrderStatus.AwaitingDispatch or OrderStatus.ReadyForPickup)
    {
        <section class="panel" style="margin-bottom: 1.5rem;">
            <div class="panel-head">
                <div>
                    <h3>Párování konkrétních kusů</h3>
                    <p class="panel-subtitle">Skladník vybírá konkrétní výrobní čísla až po objednání. Zákazník sériová čísla předem nevidí.</p>
                </div>
            </div>

            @foreach (var item in Model.Items.Where(item => item.IsWeapon && item.Weapon is not null))
            {
                var weapon = item.Weapon!;
                var selectableUnits = weapon.Units
                    .Where(unit => unit.Status == WeaponShop.Domain.WeaponUnitStatus.InStock || (unit.Status == WeaponShop.Domain.WeaponUnitStatus.Reserved && unit.ReservedOrderId == Model.Id))
                    .OrderBy(unit => unit.PrimarySerialNumber)
                    .ToList();
                var assignedIds = weapon.Units
                    .Where(unit => unit.Status == WeaponShop.Domain.WeaponUnitStatus.Reserved && unit.ReservedOrderId == Model.Id)
                    .Select(unit => unit.Id)
                    .ToHashSet();

                <form asp-action="AssignUnits" method="post" style="margin-bottom: 1rem;">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="weaponId" value="@weapon.Id" />

                    <div class="panel" style="margin-bottom: 0;">
                        <h4>@item.GetDisplayName()</h4>
                        <div class="panel-subtitle">Požadovaný počet kusů: @item.Quantity</div>

                        @if (selectableUnits.Count == 0)
                        {
                            <div class="data-empty">Není dostupný žádný naskladněný kus pro spárování.</div>
                        }
                        else
                        {
                            <div class="grid-two" style="margin-top: 1rem;">
                                @foreach (var unit in selectableUnits)
                                {
                                    <label class="panel" style="display:block;">
                                        <input type="checkbox" name="selectedUnitIds" value="@unit.Id" @(assignedIds.Contains(unit.Id) ? "checked" : null) />
                                        <strong style="display:block; margin-top:.4rem;">@unit.PrimarySerialNumber</strong>
                                        <div class="panel-subtitle">Stav: @unit.Status</div>
                                        @if (!string.IsNullOrWhiteSpace(unit.Notes))
                                        {
                                            <div class="panel-subtitle">@unit.Notes</div>
                                        }
                                        @foreach (var part in unit.Parts.OrderBy(part => part.SlotNumber))
                                        {
                                            <div class="panel-subtitle">@part.PartName: @part.SerialNumber</div>
                                        }
                                    </label>
                                }
                            </div>

                            <div class="hero-actions" style="margin-top: 1rem;">
                                <button type="submit" class="btn-modern">Uložit párování</button>
                                <span class="panel-subtitle">Vyber přesně @item.Quantity kus(y) pro tuto položku.</span>
                            </div>
                        }
                    </div>
                </form>
            }
        </section>
    }

    <div class="audit-list">
        @if (Model.Audits.Count == 0)
        {
            <div class="data-empty">Zatím nejsou k dispozici žádné auditní záznamy.</div>
        }
        else
        {
            @foreach (var audit in Model.Audits.OrderByDescending(a => a.OccurredAtUtc))
            {
                <div class="audit-card">
                    <div class="audit-card-head">
                        <div class="audit-card-title">@CatalogPresentation.GetAuditActionLabel(audit.Action)</div>
                        <span class="badge-cat">@CatalogPresentation.GetStatusLabel(audit.ToStatus)</span>
                    </div>
                    <div class="audit-card-meta">
                        @audit.OccurredAtUtc.ToLocalTime().ToString("g")
                        • @audit.ActorName
                        • @CatalogPresentation.GetStatusLabel(audit.FromStatus) → @CatalogPresentation.GetStatusLabel(audit.ToStatus)
                    </div>
                    @if (!string.IsNullOrWhiteSpace(audit.Notes))
                    {
                        <div class="audit-card-notes">Poznámka: @audit.Notes</div>
                    }
                </div>
            }
        }
    </div>
</section>
