@model IReadOnlyList<Weapon>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Sklad zbraní</h2>
            <p class="panel-subtitle">Správa zbraní, popisů, skladových zásob a dostupnosti v katalogu.</p>
        </div>
        <div class="btn-row">
            <a class="btn-soft" asp-controller="Accessories" asp-action="Index">Správa doplňků</a>
            @if (User.IsInRole("Admin"))
            {
                <a class="btn-modern" asp-action="Create">Přidat zbraň</a>
            }
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="data-empty">Žádné zbraně nebyly nalezeny.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Název</th>
                        <th>Kategorie</th>
                        <th>Výrobce</th>
                        <th class="text-end">Cena</th>
                        <th class="text-end">Sklad</th>
                        <th>Dostupnost</th>
                        <th class="text-end">Akce</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var weapon in Model)
                    {
                        <tr>
                            <td>@weapon.Name</td>
                            <td><span class="badge-cat">@weapon.Category</span></td>
                            <td>@weapon.Manufacturer</td>
                            <td class="text-end">@weapon.Price.ToString("C")</td>
                            <td class="text-end">@weapon.StockQuantity</td>
                            <td>@(weapon.IsAvailable ? "Dostupné" : "Skryté")</td>
                            <td class="text-end">
                                <div class="btn-row">
                                    <a class="btn-inline" asp-action="Edit" asp-route-id="@weapon.Id">
                                        @(User.IsInRole("Skladnik") && !User.IsInRole("Admin") ? "Upravit sklad" : "Upravit")
                                    </a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a class="btn-inline btn-inline-danger" asp-action="Delete" asp-route-id="@weapon.Id">Smazat</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
