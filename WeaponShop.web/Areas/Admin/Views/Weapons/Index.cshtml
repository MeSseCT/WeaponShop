@model IReadOnlyList<Weapon>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Sklad zbraní</h2>
            <p class="panel-subtitle">Správa zbraní, popisů, skladových zásob a dostupnosti v katalogu.</p>
        </div>
        <div class="btn-row">
            <a class="btn-soft" asp-controller="Accessories" asp-action="Index">Správa doplňků</a>
            @if (User.IsInRole("Admin"))
            {
                <a class="btn-modern" asp-action="Create">Přidat zbraň</a>
            }
        </div>
    </div>

    <form method="get" class="form-shell form-shell-wide" style="margin-bottom: 1rem;">
        <div class="grid-two">
            <div class="form-group">
                <label class="field-label" for="search">Vyhledat zbraň nebo sériové číslo</label>
                <input id="search" name="search" class="form-control" value="@(ViewData["Search"] as string ?? string.Empty)" placeholder="Název, typ, výrobce, výrobní číslo kusu nebo sériové číslo části" />
            </div>
        </div>
        <div class="btn-row">
            <button class="btn-modern" type="submit">Vyhledat</button>
            <a class="btn-soft" asp-action="Index">Vymazat filtr</a>
        </div>
    </form>

    @if (Model.Count == 0)
    {
        <div class="data-empty">Žádné zbraně neodpovídají zadanému filtru.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Název</th>
                        <th>Typ / kalibr</th>
                        <th>Kategorie</th>
                        <th>Výrobce / evidence</th>
                        <th class="text-end">Cena</th>
                        <th class="text-end">Sklad</th>
                        <th>Dostupnost</th>
                        <th class="text-end">Akce</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var weapon in Model)
                    {
                        <tr>
                            <td>
                                <div>@weapon.Name</div>
                                <div class="panel-subtitle">@weapon.Units.Count evidovaných kusů</div>
                            </td>
                            <td>
                                <div>@weapon.TypeDesignation</div>
                                <div class="panel-subtitle">@weapon.Caliber</div>
                            </td>
                            <td><span class="badge-cat">@CatalogPresentation.GetWeaponCategoryLabel(weapon.Category)</span></td>
                            <td>
                                <div>@weapon.Manufacturer</div>
                                <div class="panel-subtitle">Dostupné kusy: @weapon.StockQuantity</div>
                            </td>
                            <td class="text-end">@weapon.Price.ToString("C")</td>
                            <td class="text-end">@weapon.StockQuantity</td>
                            <td>@(weapon.IsAvailable ? "Dostupné" : "Skryté")</td>
                            <td class="text-end">
                                <div class="btn-row">
                                    <a class="btn-inline" asp-action="Edit" asp-route-id="@weapon.Id">
                                        @(User.IsInRole("Skladnik") && !User.IsInRole("Admin") ? "Upravit sklad" : "Upravit")
                                    </a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a class="btn-inline btn-inline-danger" asp-action="Delete" asp-route-id="@weapon.Id">Smazat</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
