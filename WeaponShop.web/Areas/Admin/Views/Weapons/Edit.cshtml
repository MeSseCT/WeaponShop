@model WeaponInputModel

<section class="form-shell form-shell-wide">
    <h2>Edit weapon</h2>
    <p class="auth-sub">Update item details with full validation checks.</p>

    <form asp-action="Edit" method="post">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <partial name="_WeaponForm" model="Model" />
        <div class="hero-actions">
            <button class="btn-modern" type="submit">Save changes</button>
            <a class="btn-soft" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>
