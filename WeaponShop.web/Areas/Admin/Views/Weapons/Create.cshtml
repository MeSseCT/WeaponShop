@model WeaponInputModel

<section class="form-shell form-shell-wide">
    <h2>Create weapon</h2>
    <p class="auth-sub">New product item available in admin catalog management.</p>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <partial name="_WeaponForm" model="Model" />
        <div class="hero-actions">
            <button class="btn-modern" type="submit">Create</button>
            <a class="btn-soft" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>
