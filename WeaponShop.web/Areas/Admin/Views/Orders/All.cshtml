@model IReadOnlyList<Order>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>All orders</h2>
            <p class="panel-subtitle">Full history of every order in the system.</p>
        </div>
        <div class="btn-row">
            <a class="btn-soft" asp-action="Index">Back to approvals</a>
        </div>
    </div>

    <form method="get" class="form-shell form-shell-wide" style="margin-bottom: 1rem;">
        <div class="grid-two">
            <div class="mb-3">
                <label class="field-label" for="statusFilter">Status filter</label>
                <select id="statusFilter" name="status" class="form-control">
                    <option value="">All</option>
                    @foreach (var status in Enum.GetValues<OrderStatus>())
                    {
                        var selected = string.Equals(Context.Request.Query["status"], status.ToString(), StringComparison.OrdinalIgnoreCase);
                        <option value="@status" selected="@(selected ? "selected" : null)">@status</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="field-label" for="searchQuery">Search (order id / email / name)</label>
                <input id="searchQuery" name="q" class="form-control" value="@Context.Request.Query["q"]" />
            </div>
        </div>
        <button class="btn-modern" type="submit">Apply filter</button>
    </form>

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        <div class="data-empty">@statusMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="data-empty">@errorMessage</div>
    }

    @if (Model.Count == 0)
    {
        <div class="data-empty">No orders found.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Status</th>
                        <th>Customer</th>
                        <th>Items</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>
                                <div>#@order.Id</div>
                                <div class="panel-subtitle">@order.CreatedAt.ToLocalTime().ToString("g")</div>
                            </td>
                            <td><span class="badge-cat">@order.Status</span></td>
                            <td>
                                <div>@order.User?.FirstName @order.User?.LastName</div>
                                <div class="panel-subtitle">@order.User?.Email</div>
                            </td>
                            <td>@order.Items.Count</td>
                            <td class="text-end">@order.TotalPrice.ToString("C")</td>
                            <td class="text-end">
                                <div class="btn-row">
                                    <a class="btn-inline" asp-area="Admin" asp-action="Details" asp-route-id="@order.Id">Details</a>
                                    <a class="btn-inline" asp-area="Admin" asp-action="DownloadWord" asp-route-id="@order.Id">Word</a>
                                    <form asp-area="Admin" asp-action="DeleteHistory" method="post">
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="btn-inline btn-inline-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
