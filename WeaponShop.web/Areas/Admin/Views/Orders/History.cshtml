@model IReadOnlyList<Order>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Historie objednávek zákazníka</h2>
            <p class="panel-subtitle">Přehled všech objednávek vybraného zákazníka.</p>
        </div>
        <div class="btn-row">
            <a class="btn-soft" asp-action="Index">Zpět na schvalování</a>
            <a class="btn-soft" asp-action="All">Všechny objednávky</a>
        </div>
    </div>

    <form method="get" class="form-shell form-shell-wide" style="margin-bottom: 1rem;">
        <input type="hidden" name="userId" value="@Context.Request.Query["userId"]" />
        <div class="mb-3">
            <label class="field-label" for="statusFilter">Filtr stavu</label>
            <select id="statusFilter" name="status" class="form-control">
                <option value="">Vše</option>
                @foreach (var status in Enum.GetValues<OrderStatus>())
                {
                    var selected = string.Equals(Context.Request.Query["status"], status.ToString(), StringComparison.OrdinalIgnoreCase);
                    <option value="@status" selected="@(selected ? "selected" : null)">@CatalogPresentation.GetStatusLabel(status)</option>
                }
            </select>
        </div>
        <button class="btn-modern" type="submit">Použít filtr</button>
    </form>

    @if (Model.Count == 0)
    {
        <div class="data-empty">Pro tohoto zákazníka nebyly nalezeny žádné objednávky.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Objednávka</th>
                        <th>Stav</th>
                        <th>Zákazník</th>
                        <th>Položky</th>
                        <th>Audit</th>
                        <th class="text-end">Akce</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>
                                <div>@order.GetPublicOrderNumber()</div>
                                <div class="panel-subtitle">@order.CreatedAt.ToLocalTime().ToString("g")</div>
                            </td>
                            <td><span class="badge-cat">@CatalogPresentation.GetStatusLabel(order.Status)</span></td>
                            <td>
                                <div>@order.User?.FirstName @order.User?.LastName</div>
                                <div class="panel-subtitle">@order.User?.Email</div>
                            </td>
                            <td>
                                @foreach (var item in order.Items)
                                {
                                    <div>@item.GetDisplayName() x @item.Quantity</div>
                                }
                            </td>
                            <td>
                                <div class="audit-list compact">
                                    @if (order.Audits.Count == 0)
                                    {
                                        <div class="panel-subtitle">Zatím bez auditu</div>
                                    }
                                    else
                                    {
                                        foreach (var audit in order.Audits.OrderByDescending(a => a.OccurredAtUtc))
                                        {
                                            <div class="audit-chip">
                                                @audit.OccurredAtUtc.ToLocalTime().ToString("g")
                                                • @audit.ActorName
                                                • @CatalogPresentation.GetAuditActionLabel(audit.Action)
                                            </div>
                                        }
                                    }
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="btn-row">
                                    <a class="btn-inline" asp-area="Admin" asp-action="Details" asp-route-id="@order.Id">Zobrazit</a>
                                    <a class="btn-inline" asp-area="Admin" asp-action="DownloadWord" asp-route-id="@order.Id">Stáhnout DOC</a>
                                    <form asp-area="Admin" asp-action="DeleteHistory" method="post">
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="btn-inline btn-inline-danger">Smazat</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
