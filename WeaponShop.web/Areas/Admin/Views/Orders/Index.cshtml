@model IReadOnlyList<Order>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Administrace schvalování</h2>
            <p class="panel-subtitle">Objednávky čekající na ruční ověření dokladů a schválení.</p>
        </div>
        <div class="btn-row">
            <a class="btn-soft" asp-area="Admin" asp-controller="Weapons" asp-action="Index">Správa produktů</a>
            <a class="btn-soft" asp-area="Admin" asp-action="All">Všechny objednávky</a>
        </div>
    </div>

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        <div class="data-empty">@statusMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="data-empty">@errorMessage</div>
    }

    @if (Model.Count == 0)
    {
        <div class="data-empty">Žádné objednávky momentálně nečekají na schválení.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Objednávka</th>
                        <th>Zákazník</th>
                        <th>Doklady</th>
                        <th>Audit</th>
                        <th class="text-end">Položky</th>
                        <th class="text-end">Celkem</th>
                        <th class="text-end">Akce</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>
                                <div>#@order.Id</div>
                                <div class="panel-subtitle">@order.CreatedAt.ToLocalTime().ToString("g")</div>
                            </td>
                            <td>
                                <div>@order.User?.FirstName @order.User?.LastName</div>
                                <div class="panel-subtitle">@order.User?.Email</div>
                                <div>
                                    <a class="btn-inline" asp-area="Admin" asp-controller="Orders" asp-action="History" asp-route-userId="@order.UserId">Historie</a>
                                </div>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(order.User?.IdCardFileName))
                                {
                                    var idCardIsPdf = order.User?.IdCardFileName?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) ?? false;
                                    var idCardViewUrl = Url.Action("ViewDocument", "Account", new { area = "", userId = order.UserId, type = "idcard" });
                                    var idCardDownloadUrl = Url.Action("DownloadDocument", "Account", new { area = "", userId = order.UserId, type = "idcard" });
                                    <button type="button"
                                            class="btn-inline doc-open"
                                            data-doc-title="Občanský průkaz"
                                            data-doc-kind="@(idCardIsPdf ? "pdf" : "image")"
                                            data-doc-url="@idCardViewUrl"
                                            data-doc-download="@idCardDownloadUrl">
                                        Zobrazit OP
                                    </button>
                                }
                                else
                                {
                                    <span class="panel-subtitle">Občanský průkaz chybí</span>
                                }

                                @if (!string.IsNullOrWhiteSpace(order.User?.DriverLicenseFileName))
                                {
                                    var driverLicenseIsPdf = order.User?.DriverLicenseFileName?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) ?? false;
                                    var driverLicenseViewUrl = Url.Action("ViewDocument", "Account", new { area = "", userId = order.UserId, type = "driverlicense" });
                                    var driverLicenseDownloadUrl = Url.Action("DownloadDocument", "Account", new { area = "", userId = order.UserId, type = "driverlicense" });
                                    <button type="button"
                                            class="btn-inline doc-open"
                                            data-doc-title="Řidičský průkaz"
                                            data-doc-kind="@(driverLicenseIsPdf ? "pdf" : "image")"
                                            data-doc-url="@driverLicenseViewUrl"
                                            data-doc-download="@driverLicenseDownloadUrl">
                                        Zobrazit ŘP
                                    </button>
                                }
                                else
                                {
                                    <span class="panel-subtitle">Řidičský průkaz chybí</span>
                                }
                            </td>
                            <td>
                                @if (order.Audits.Count == 0)
                                {
                                    <span class="panel-subtitle">Zatím bez auditu</span>
                                }
                                else
                                {
                                    foreach (var audit in order.Audits.OrderByDescending(a => a.OccurredAtUtc))
                                    {
                                        <div class="panel-subtitle">
                                            @audit.OccurredAtUtc.ToLocalTime().ToString("g") -
                                            @audit.ActorRole @audit.ActorName: @audit.Action
                                        </div>
                                    }
                                }
                            </td>
                            <td class="text-end">@order.Items.Count</td>
                            <td class="text-end">@order.TotalPrice.ToString("C")</td>
                            <td class="text-end">
                                <div class="btn-row">
                                    <a class="btn-inline" asp-area="Admin" asp-action="Details" asp-route-id="@order.Id">Detail</a>
                                    <form asp-action="Approve" method="post">
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <button type="submit" class="btn-inline">Schválit</button>
                                    </form>
                                    <form asp-action="Reject" method="post">
                                        <input type="hidden" name="id" value="@order.Id" />
                                        <button type="submit" class="btn-inline btn-inline-danger">Zamítnout</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<div class="doc-modal" id="docModal" aria-hidden="true">
    <div class="doc-modal-backdrop" data-doc-close="true"></div>
    <div class="doc-modal-card" role="dialog" aria-modal="true" aria-labelledby="docModalTitle">
        <div class="doc-modal-head">
            <div class="doc-modal-title" id="docModalTitle">Dokument</div>
            <div class="doc-modal-actions">
                <a class="btn-soft" data-doc-download href="#" rel="noopener">Stáhnout</a>
                <button type="button" class="btn-inline doc-modal-close" data-doc-close="true" aria-label="Zavřít">×</button>
            </div>
        </div>
        <div class="doc-modal-body">
            <img class="doc-modal-image" data-doc-image alt="Náhled dokumentu" />
            <iframe class="doc-modal-frame" data-doc-frame title="Náhled dokumentu"></iframe>
            <div class="doc-modal-fallback" data-doc-fallback>
                Náhled není dostupný. Použijte stažení dokumentu.
            </div>
        </div>
    </div>
</div>

<script>
    (() => {
        const modal = document.getElementById("docModal");
        if (!modal) {
            return;
        }

        const title = modal.querySelector("[data-doc-title]") || modal.querySelector("#docModalTitle");
        const image = modal.querySelector("[data-doc-image]");
        const frame = modal.querySelector("[data-doc-frame]");
        const fallback = modal.querySelector("[data-doc-fallback]");
        const download = modal.querySelector("[data-doc-download]");

        const openModal = (button) => {
            const url = button.dataset.docUrl;
            const kind = button.dataset.docKind;
            const docTitle = button.dataset.docTitle || "Dokument";
            const downloadUrl = button.dataset.docDownload || url;

            if (title) {
                title.textContent = docTitle;
            }

            if (download) {
                download.setAttribute("href", downloadUrl);
            }

            image.style.display = "none";
            frame.style.display = "none";
            fallback.style.display = "none";

            if (!url) {
                fallback.style.display = "block";
            } else if (kind === "pdf") {
                frame.src = url;
                frame.style.display = "block";
            } else {
                image.src = url;
                image.style.display = "block";
            }

            modal.classList.add("is-open");
            modal.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";
        };

        const closeModal = () => {
            modal.classList.remove("is-open");
            modal.setAttribute("aria-hidden", "true");
            image.src = "";
            frame.src = "";
            document.body.style.overflow = "";
        };

        document.querySelectorAll(".doc-open").forEach((button) => {
            button.addEventListener("click", () => openModal(button));
        });

        modal.querySelectorAll("[data-doc-close]").forEach((button) => {
            button.addEventListener("click", closeModal);
        });

        document.addEventListener("keydown", (event) => {
            if (event.key === "Escape" && modal.classList.contains("is-open")) {
                closeModal();
            }
        });
    })();
</script>
