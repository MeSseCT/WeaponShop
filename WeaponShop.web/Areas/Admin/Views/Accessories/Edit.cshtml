@model WeaponShop.Web.ViewModels.Accessories.AccessoryInputModel

<section class="form-shell form-shell-wide">
    <h2>Upravit doplněk</h2>
    <p class="auth-sub">Úprava veřejné položky včetně popisu, kategorie, ceny, obrázku a skladu.</p>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <partial name="_AccessoryForm" model="Model" />
        <div class="hero-actions">
            <button class="btn-modern" type="submit">Uložit změny</button>
            <a class="btn-soft" asp-action="Index">Zrušit</a>
        </div>
    </form>
</section>
