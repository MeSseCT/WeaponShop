@model IReadOnlyList<Accessory>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Doplňky ve veřejném katalogu</h2>
            <p class="panel-subtitle">Správa optiky, uložení, ochranných potřeb a dalších veřejných položek.</p>
        </div>
        <div class="btn-row">
            <a class="btn-soft" asp-controller="Weapons" asp-action="Index">Zbraně</a>
            <a class="btn-modern" asp-action="Create">Přidat doplněk</a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="data-empty">Žádné doplňky nebyly nalezeny.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Název</th>
                        <th>Kategorie</th>
                        <th>Výrobce</th>
                        <th class="text-end">Cena</th>
                        <th class="text-end">Sklad</th>
                        <th>Dostupnost</th>
                        <th class="text-end">Akce</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var accessory in Model)
                    {
                        <tr>
                            <td>@accessory.Name</td>
                            <td><span class="badge-chip badge-chip-public">@CatalogPresentation.GetAccessoryCategoryLabel(accessory.Category)</span></td>
                            <td>@accessory.Manufacturer</td>
                            <td class="text-end">@accessory.Price.ToString("C")</td>
                            <td class="text-end">@accessory.StockQuantity</td>
                            <td>@(accessory.IsAvailable ? "Dostupné" : "Skryté")</td>
                            <td class="text-end">
                                <div class="btn-row">
                                    <a class="btn-inline" asp-action="Edit" asp-route-id="@accessory.Id">
                                        @(User.IsInRole("Skladnik") && !User.IsInRole("Admin") ? "Upravit sklad" : "Upravit")
                                    </a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a class="btn-inline btn-inline-danger" asp-action="Delete" asp-route-id="@accessory.Id">Smazat</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
