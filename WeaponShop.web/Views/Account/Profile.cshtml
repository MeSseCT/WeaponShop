@model WeaponShop.Web.ViewModels.Account.ProfileViewModel

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Profil</h2>
            <p class="panel-subtitle">Doplňte datum narození tak, aby odpovídalo občanskému nebo řidičskému průkazu.</p>
        </div>
    </div>

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        <div class="data-empty">@statusMessage</div>
    }

    <form asp-action="Profile" method="post" class="form-shell">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label asp-for="DateOfBirth" class="field-label"></label>
            <input asp-for="DateOfBirth" type="date" class="form-control" />
            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
        </div>
        <button class="btn-modern" type="submit">Uložit změny</button>
    </form>
</section>

<section class="panel" style="margin-top: 1.2rem;">
    <div class="panel-head">
        <div>
            <h2>Ověřovací doklady</h2>
            <p class="panel-subtitle">Nahrajte občanský nebo řidičský průkaz pro ruční kontrolu administrátorem.</p>
        </div>
    </div>

    <div class="panel" style="margin-bottom: 1rem;">
        <p class="panel-subtitle">Občanský průkaz nahrán: @(Model.HasIdCard ? "Ano" : "Ne")</p>
        <p class="panel-subtitle">Řidičský průkaz nahrán: @(Model.HasDriverLicense ? "Ano" : "Ne")</p>
        @if (Model.DocumentsUpdatedAt.HasValue)
        {
            <p class="panel-subtitle">Poslední aktualizace: @Model.DocumentsUpdatedAt.Value.ToLocalTime().ToString("g")</p>
        }
    </div>

    <form asp-action="Documents" method="post" enctype="multipart/form-data" class="form-shell form-shell-wide">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="IdCardFile" class="field-label">Občanský průkaz (PDF/JPG/PNG, max. 5 MB)</label>
            <input asp-for="IdCardFile" type="file" class="form-control" />
            <span asp-validation-for="IdCardFile" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="DriverLicenseFile" class="field-label">Řidičský průkaz (PDF/JPG/PNG, max. 5 MB)</label>
            <input asp-for="DriverLicenseFile" type="file" class="form-control" />
            <span asp-validation-for="DriverLicenseFile" class="text-danger"></span>
        </div>

        <button class="btn-modern" type="submit">Nahrát doklady</button>
    </form>
</section>
