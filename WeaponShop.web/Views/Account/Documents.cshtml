@model WeaponShop.Web.ViewModels.Account.DocumentsViewModel

<section class="form-shell">
    <h2>Ověřovací doklady</h2>
    <p class="auth-sub">Nahrajte občanský nebo řidičský průkaz pro ruční ověření administrátorem.</p>

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        <div class="data-empty">@statusMessage</div>
    }

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="panel" style="margin-bottom: 1rem;">
        <p class="panel-subtitle">Občanský průkaz nahrán: @(Model.HasIdCard ? "Ano" : "Ne")</p>
        <p class="panel-subtitle">Řidičský průkaz nahrán: @(Model.HasDriverLicense ? "Ano" : "Ne")</p>
        @if (Model.DocumentsUpdatedAt.HasValue)
        {
            <p class="panel-subtitle">Poslední aktualizace: @Model.DocumentsUpdatedAt.Value.ToLocalTime().ToString("g")</p>
        }
    </div>

    <form asp-action="Documents" method="post" enctype="multipart/form-data">
        <div class="mb-3">
            <label asp-for="IdCardFile" class="field-label">Občanský průkaz (PDF/JPG/PNG, max. 5 MB)</label>
            <input asp-for="IdCardFile" type="file" class="form-control" />
        </div>

        <div class="mb-4">
            <label asp-for="DriverLicenseFile" class="field-label">Řidičský průkaz (PDF/JPG/PNG, max. 5 MB)</label>
            <input asp-for="DriverLicenseFile" type="file" class="form-control" />
        </div>

        <div class="hero-actions">
            <button class="btn-modern" type="submit">Nahrát doklady</button>
            <a class="btn-soft" asp-controller="Home" asp-action="Index">Zpět</a>
        </div>
    </form>
</section>
