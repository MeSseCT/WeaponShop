@model IReadOnlyList<WeaponShop.Domain.Notification>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Notifikace</h2>
            <p class="panel-subtitle">Přehled všech aktualizací týkajících se vašich objednávek.</p>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="data-empty">Zatím nemáte žádné notifikace.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Nadpis</th>
                        <th>Zpráva</th>
                        <th>Datum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var notification in Model)
                    {
                        <tr>
                            <td>@notification.Title</td>
                            <td>@notification.Message</td>
                            <td>@notification.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
