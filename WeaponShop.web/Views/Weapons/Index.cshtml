@model IReadOnlyList<Weapon>

<section class="panel">
    <div class="panel-head">
        <div>
            <h2>Products</h2>
            <p class="panel-subtitle">Current catalog preview available for customers.</p>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="data-empty">No products found.</div>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-grid">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Manufacturer</th>
                        <th class="text-end">Price</th>
                        @if (User.IsInRole("Customer"))
                        {
                            <th class="text-end">Action</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var weapon in Model)
                    {
                        <tr>
                            <td>@weapon.Name</td>
                            <td><span class="badge-cat">@weapon.Category</span></td>
                            <td>@weapon.Manufacturer</td>
                            <td class="text-end">@weapon.Price.ToString("C")</td>
                            @if (User.IsInRole("Customer"))
                            {
                                <td class="text-end">
                                    <form asp-controller="Cart" asp-action="Add" method="post">
                                        <input type="hidden" name="weaponId" value="@weapon.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn-soft">Add to cart</button>
                                    </form>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
