@{
    ViewData["Title"] = "Úvod";
}

<section class="hero hero-shell">
    <div class="hero-copy">
        <div class="hero-stack">
            <p class="hero-kicker">Obchod se zbraněmi a střeleckými doplňky</p>
            <h1>Zbraně, optika a vybavení pro střelce.</h1>
            <p>
                Doplňky můžete objednat ihned. Pro zobrazení a nákup zbraní na zbrojní průkaz je nutné přihlášení,
                potvrzení věku 18+ a nahrání potřebných dokladů.
            </p>
        </div>

        <div class="hero-actions">
            <a class="btn-modern" asp-controller="Weapons" asp-action="Index">Prohlédnout celý katalog</a>
            <a class="btn-soft" asp-controller="Weapons" asp-action="Index" asp-route-access="accessories">Zobrazit doplňky</a>
        </div>

        <div class="hero-trustbar">
            <div>
                <strong>Volně dostupné</strong>
                <span>Optika, pouzdra, vzduchovky a ochranné potřeby</span>
            </div>
            <div>
                <strong>Po ověření účtu</strong>
                <span>Zbraně se zobrazí po kontrole věku a dokladů</span>
            </div>
            <div>
                <strong>Osobní odběr</strong>
                <span>Objednávky se zbraněmi se dokončují podle pravidel obchodu</span>
            </div>
        </div>
    </div>

    <aside class="hero-stage">
        <div class="hero-stage-card hero-stage-card-classic">
            <span class="hero-stage-tag">Nákup zbraní</span>
            <h2>Pro zobrazení zbraní je potřeba ověřený účet.</h2>
            <ol class="hero-steps">
                <li>Vytvořte si zákaznický účet a vyplňte svůj profil.</li>
                <li>Potvrďte věk 18+ a nahrajte občanský průkaz nebo nákupní povolení.</li>
                <li>Po ověření účtu se zpřístupní katalog zbraní a jejich detaily.</li>
            </ol>
        </div>
    </aside>
</section>

<section class="promo-banner panel">
    <div class="promo-banner-copy">
        <p class="section-kicker">Oblíbené kategorie</p>
        <h2>Optika, pouzdra, sebeobrana, vzduchovky i zbraně na zbrojní průkaz.</h2>
        <p class="panel-subtitle">Vyberte si kategorii, přejděte do detailu produktu a pokračujte standardně do košíku.</p>
        <div class="hero-actions">
            <a class="btn-modern" asp-controller="Weapons" asp-action="Index" asp-route-access="accessories">Nakoupit doplňky</a>
            <a class="btn-soft" asp-controller="Account" asp-action="Register">Vytvořit zákaznický účet</a>
        </div>
    </div>
    <div class="promo-banner-points">
        <div class="promo-point">
            <strong>Optika</strong>
            <span>Kolimátory, zaměřovače a montáže</span>
        </div>
        <div class="promo-point">
            <strong>Pouzdra a uložení</strong>
            <span>Bezpečné přenášení i domácí skladování</span>
        </div>
        <div class="promo-point">
            <strong>Ochranné potřeby</strong>
            <span>Brýle, sluchátka a střelecké příslušenství</span>
        </div>
    </div>
</section>

<section class="home-categories">
    <div class="section-header">
        <div>
            <p class="section-kicker">Kategorie obchodu</p>
            <h2>Vyberte sekci, která vás zajímá</h2>
            <p class="panel-subtitle">Doplňky jsou dostupné ihned. Zbraně se zobrazují až po ověření zákaznického účtu.</p>
        </div>
    </div>

    <div class="category-grid">
        <a class="category-tile category-tile-featured" asp-controller="Weapons" asp-action="Index" asp-route-access="accessories">
            <span class="category-eyebrow">Volně dostupné</span>
            <h3>Doplňky</h3>
            <p>Optika, pouzdra, sebeobranné prostředky a další vybavení dostupné k okamžitému nákupu.</p>
        </a>
        <a class="category-tile" asp-controller="Weapons" asp-action="Index" asp-route-access="accessories" asp-route-accessoryCategory="Optics">
            <span class="category-eyebrow">Doplňky</span>
            <h3>Optika</h3>
            <p>Kolimátory, zaměřovače a další vybavení pro přesnou střelbu.</p>
        </a>
        <a class="category-tile" asp-controller="Weapons" asp-action="Index" asp-route-access="restricted" asp-route-legalCategory="B">
            <span class="category-eyebrow">Po ověření účtu</span>
            <h3>Kategorie B</h3>
            <p>Krátké a další zbraně dostupné zákazníkům s ověřeným profilem a doklady.</p>
        </a>
        <a class="category-tile" asp-controller="Weapons" asp-action="Index" asp-route-access="restricted" asp-route-legalCategory="C">
            <span class="category-eyebrow">Po ověření účtu</span>
            <h3>Kategorie C</h3>
            <p>Dlouhé zbraně a sportovní varianty po přihlášení, potvrzení věku a kontrole dokladů.</p>
        </a>
    </div>
</section>
